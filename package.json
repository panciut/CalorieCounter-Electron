{
  "name": "caloriecounter",
  "version": "1.0.0",
  "description": "Calorie & weight tracker",
  "main": "main/main.js",
  "scripts": {
    "dev": "concurrently -k -n vite,electron -c cyan,magenta \"npm run dev:vite\" \"wait-on http://localhost:5199 && npm run dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "electron .",
    "start": "electron .",
    "build": "vite build",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "dist": "vite build && electron-builder"
  },
  "build": {
    "appId": "com.caloriecounter.app",
    "productName": "CalorieCounter",
    "mac": {
      "target": "dmg",
      "category": "public.app-category.healthcare-fitness",
      "icon": "build/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "extendInfo": {
        "NSCameraUsageDescription": "CalorieCounter uses the camera to scan food barcodes.",
        "NSMicrophoneUsageDescription": "CalorieCounter does not record audio; this is required by the camera API."
      }
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    },
    "files": [
      "main/**/*",
      "dist/**/*",
      "node_modules/**/*"
    ],
    "extraMetadata": {
      "main": "main/main.js"
    }
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/recharts": "^1.8.29",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^33.0.0",
    "electron-builder": "^26.8.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "wait-on": "^9.0.5"
  },
  "dependencies": {
    "better-sqlite3": "^11.5.0",
    "fuse.js": "^7.0.0",
    "html5-qrcode": "^2.3.8",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "recharts": "^3.8.1"
  }
}
